# Ignore ALL files in ANY directory named build
eigen/
Eigen/
build/
build-*/
build_stage*/
scratchpad/
unstructured_dft/
.cache/
.venv/
__pycache__/
*.py[cod]
*.pyo
.vscode/*
!.vscode/
!.vscode/settings.json
tasks.json
Makefile
output/
CMakeFiles/
CMakeCache.txt
.ninja_log
.ninja_deps
Testing/
*.cmake
*.tcl
*.msh
# fixture hermetico de los tests de validacion (generado una vez con
# `gmsh validation_cube.geo -3 -order 2`; ver encabezado del .geo)
!tests/validation_cube.msh
# cache de preferencias de la GUI de Gmsh (contiene rutas absolutas locales)
*.geo.opt
*.exe
tmp_*.log
tmp_*.py
*.tmp
*.bak
doc/latex_out.txt
data/tmp/
data/output/
!data/output/.gitkeep
data/output/cyclic_validation/tmp_*/
data/output/cyclic_validation/reboot_*/
data/output/cyclic_validation/*_smoke/
data/output/cyclic_validation/*_dry_run/
PhD_Thesis/Figuras/validation_reboot/*.pdf

